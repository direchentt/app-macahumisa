PORT=3000
NODE_ENV=development

# PostgreSQL (local o Supabase: copiá la URI del panel → Database)
DATABASE_URL=postgres://user:pass@localhost:5432/macahumisa

# JWT (mínimo 16 caracteres; en producción usá uno largo y aleatorio)
JWT_SECRET=cambiar_por_secreto_largo_y_aleatorio

# Producción (Render, Railway, etc.): mismas claves en el panel del host.
# Render suele definir PORT solo; no hace falta ponerlo en el .env del servidor.
