PORT=3000
NODE_ENV=development

# PostgreSQL (local o Supabase: copiá la URI del panel → Database)
DATABASE_URL=postgres://user:pass@localhost:5432/macahumisa
#
# Railway / Docker: si ves errores tipo ENETUNREACH a una IP IPv6 (:5432), la app fuerza preferencia IPv4 al arrancar.
# Si sigue fallando, en Railway usá la URL **interna** del Postgres del mismo proyecto, o el hostname "pooler" que ofrezca tu proveedor (Neon, etc.).
#
# Supabase pooler (*.pooler.supabase.com): el código usa SSL sin verificar cadena estricta (rejectUnauthorized: false), que suele ser necesario en Railway.
# Para forzar: DATABASE_SSL_REJECT_UNAUTHORIZED=0 (relajar) o =1 (estricto).

# JWT (mínimo 16 caracteres; en producción usá uno largo y aleatorio)
JWT_SECRET=cambiar_por_secreto_largo_y_aleatorio

# Si el front está en otro dominio (ej. Vercel) y la API en Railway/Render, listá orígenes separados por coma:
# CORS_ORIGIN=https://tu-app.vercel.app,https://www.tudominio.com
# Con un solo deploy (API sirve también la web desde web/dist) no hace falta.

# Producción (Render, Railway, etc.): mismas claves en el panel del host.
# Render suele definir PORT solo; no hace falta ponerlo en el .env del servidor.

# Opcional: email vía SendGrid cuando alguien carga un gasto en una lista compartida
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=verificado@tudominio.com
